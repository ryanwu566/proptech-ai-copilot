# Optional. The MVP uses a deterministic Chinese fallback explanation without this key.
OPENAI_API_KEY=

# Comma-separated frontend origins. Defaults to localhost origins when empty.
CORS_ORIGINS=

# Optional Google Places / Geocoding backend adapter. Falls back to mock data when empty.
GOOGLE_MAPS_API_KEY=
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=
TGOS_API_KEY=
TGOS_APP_ID=

# Optional future Supabase/Postgres valuation database. Falls back safely when unset.
VALUATION_DATABASE_URL=
